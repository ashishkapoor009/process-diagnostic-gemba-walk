# ---------------------------------------------------------------------------
# Process Diagnostic / Gemba Walk Multi-Agent Solution - Environment Config
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# --- LLM Provider: "openai" or "azure_openai" ---
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Azure OpenAI (used only when LLM_PROVIDER=azure_openai) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# --- App behaviour ---
APP_ENV=development
LOG_LEVEL=INFO
RAGAS_MIN_SCORE=0.70
RAGAS_MAX_REVIEW_ROUNDS=1
TARGET_EFFICIENCY_LOW=0.25
TARGET_EFFICIENCY_HIGH=0.30

# --- Storage paths ---
SQLITE_DB_PATH=./data/pe_agent.db
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# --- OCR ---
TESSERACT_CMD=tesseract

# --- FastAPI backend (optional) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
